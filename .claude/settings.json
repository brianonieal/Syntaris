{
  "model": "claude-sonnet-4-6",
  "effort": "medium",

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/hook-wrapper.sh\" session-start 2>/dev/null || powershell.exe -File \"$USERPROFILE\\.claude\\hooks\\hook-wrapper.ps1\" session-start 2>$null; exit 0"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/hook-wrapper.sh\" strip-coauthor 2>/dev/null || powershell.exe -File \"$USERPROFILE\\.claude\\hooks\\hook-wrapper.ps1\" strip-coauthor 2>$null; exit 0"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/hook-wrapper.sh\" enforce-tests || powershell.exe -File \"$USERPROFILE\\.claude\\hooks\\hook-wrapper.ps1\" enforce-tests"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/hook-wrapper.sh\" block-dangerous || powershell.exe -File \"$USERPROFILE\\.claude\\hooks\\hook-wrapper.ps1\" block-dangerous"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/hook-wrapper.sh\" context-check 2>/dev/null || powershell.exe -File \"$USERPROFILE\\.claude\\hooks\\hook-wrapper.ps1\" context-check 2>$null; exit 0"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/hook-wrapper.sh\" pre-compact 2>/dev/null || powershell.exe -File \"$USERPROFILE\\.claude\\hooks\\hook-wrapper.ps1\" pre-compact 2>$null; exit 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/hook-wrapper.sh\" writethru-episodic 2>/dev/null || powershell.exe -File \"$USERPROFILE\\.claude\\hooks\\hook-wrapper.ps1\" writethru-episodic 2>$null; exit 0"
          }
        ]
      }
    ]
  },

  "permissions": {
    "allow": [
      "Bash(git *)", "Bash(npm *)", "Bash(pnpm *)", "Bash(python *)",
      "Bash(uvicorn *)", "Bash(alembic *)", "Bash(pytest *)", "Bash(vitest *)",
      "Bash(npx *)", "Bash(pip *)", "Bash(cat *)", "Bash(ls *)",
      "Bash(mkdir *)", "Bash(cp *)", "Bash(mv *)", "Bash(echo *)",
      "Bash(curl *)", "Bash(grep *)", "Bash(find *)", "Bash(head *)",
      "Bash(tail *)", "Bash(wc *)"
    ],
    "deny": [
      "Bash(rm -rf /)", "Bash(rm -rf ~)", "Bash(rm -rf .)", "Bash(rm -rf *)",
      "Bash(rm -fr /)", "Bash(rm -fr ~)", "Bash(rm -fr .)", "Bash(rm -fr *)",
      "Bash(rm -r -f /)", "Bash(rm -f -r /)",
      "Bash(rm --recursive --force /)", "Bash(rm --force --recursive /)",
      "Bash(rm -rf /home)", "Bash(rm -rf /usr)", "Bash(rm -rf /etc)",
      "Bash(rm -rf /var)", "Bash(rm -rf /opt)", "Bash(rm -rf /System)",
      "Bash(git push --force * main)", "Bash(git push --force * master)",
      "Bash(git push -f * main)", "Bash(git push -f * master)",
      "Bash(git push --force-with-lease * main)", "Bash(git push --force-with-lease * master)"
    ]
  },

  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp"]
    }
  },

  "env": {
    "SYNTARIS_VERSION": "v0.5.1",
    "CONTEXT_WARN_TURNS": "80",
    "CONTEXT_HARD_TURNS": "120"
  }
}

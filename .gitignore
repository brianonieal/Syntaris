# Syntaris v0.3.0 — .gitignore
#
# Keep the public repo clean. These files are either local-only,
# contain personal information, or are build artifacts.

# ── Personal configuration (never commit) ─────────────────────────────────
# owner-config.md contains your name, email, rate, and identity.
# Only owner-config.template.md is tracked in git.
personal-overlay/owner-config.md

# ── Build output ──────────────────────────────────────────────────────────
dist/

# ── Install artifacts ─────────────────────────────────────────────────────
# If a user accidentally runs install.sh inside the repo and it writes to the
# wrong place, these default SyntarisRoot locations should not be committed.
Syntaris/
Syntaris-install/

# ── Local state and logs ──────────────────────────────────────────────────
# Hook wrapper error logs and marker files written during use.
.claude/state/
bp-hook-err-*.log
tests-passing-marker

# ── Backup files ──────────────────────────────────────────────────────────
*.bak
*.orig

# ── OS artifacts ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor artifacts ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Python / Node (in case users work on scripts here) ────────────────────
__pycache__/
*.pyc
node_modules/
.venv/
venv/

# ── Secrets ───────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
